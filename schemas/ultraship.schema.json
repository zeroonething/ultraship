{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UltraShip framework configuration",
  "description": "Owns framework schema version, workspace configuration, and provider-neutral execution preferences.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "framework_version", "resource_profile"],
  "properties": {
    "schema_version": { "const": 1 },
    "framework_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?$"
    },
    "version_files": {
      "description": "Optional. Files outside .ultraship that carry the project's version. validate checks every one matches the greatest released version, so the version cannot drift across manifests. path is relative to the project root; key is a dot-path into the parsed JSON (numeric segments index arrays).",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "key"],
        "properties": {
          "path": { "type": "string" },
          "key": { "type": "string" }
        }
      }
    },
    "delivery_hooks": {
      "description": "Optional. Per target mode, the shell command that deploys or publishes the release and an optional post-deploy smoke command. `ultraship deploy` runs the command matching the release's target_mode, captures its output under evidence/<version>/, and reports a non-zero exit so completion refuses the deployed mode. The commands are the project's own tooling; ultraship makes no network call of its own. VERSION, PRODUCT, and MODE are exported to the command.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "staging-deployed": {
          "type": "object",
          "additionalProperties": false,
          "required": ["deploy"],
          "properties": { "deploy": { "type": "string" }, "smoke": { "type": "string" } }
        },
        "production-deployed": {
          "type": "object",
          "additionalProperties": false,
          "required": ["deploy"],
          "properties": { "deploy": { "type": "string" }, "smoke": { "type": "string" } }
        },
        "published": {
          "type": "object",
          "additionalProperties": false,
          "required": ["deploy"],
          "properties": { "deploy": { "type": "string" }, "smoke": { "type": "string" } }
        }
      }
    },
    "resource_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_tool", "billing_mode", "model_policy", "available", "preferences", "telemetry"],
      "properties": {
        "provider_tool": { "type": ["string", "null"] },
        "billing_mode": { "type": ["string", "null"], "enum": ["subscription", "api-credits", "local", null] },
        "model_policy": { "enum": ["auto", "economical", "premium"] },
        "available": {
          "type": "object",
          "additionalProperties": false,
          "required": ["time_minutes", "token_budget", "monetary_budget_usd", "human_review_minutes"],
          "properties": {
            "time_minutes": { "type": ["number", "null"] },
            "token_budget": { "type": ["number", "null"] },
            "monetary_budget_usd": { "type": ["number", "null"] },
            "human_review_minutes": { "type": ["number", "null"] }
          }
        },
        "preferences": {
          "type": "object",
          "additionalProperties": false,
          "required": ["minimize_cost", "allow_additional_spend", "allow_model_routing", "allow_parallel_agents"],
          "properties": {
            "minimize_cost": { "type": "boolean" },
            "allow_additional_spend": { "type": "boolean" },
            "allow_model_routing": { "type": "boolean" },
            "allow_parallel_agents": { "type": "boolean" }
          }
        },
        "telemetry": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "confidence"],
          "properties": {
            "source": {
              "description": "Where usage figures came from. There is no provider telemetry in 0.1.0, so anything beyond a user estimate is a fabrication.",
              "enum": ["unknown", "user-estimate"]
            },
            "confidence": { "enum": ["low", "medium", "high"] }
          }
        }
      }
    }
  }
}
